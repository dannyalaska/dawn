ENV=dev
APP_NAME=DAWN
PORT=8000

# ── Infra ──────────────────────────────────────────────────────────────────────
POSTGRES_DSN=postgresql+psycopg2://dawn:password@localhost:5432/dawn
REDIS_URL=redis://localhost:6379/1

# S3 / compatible object store
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=changeme
AWS_SECRET_ACCESS_KEY=changeme
S3_BUCKET=dawn-dev
S3_ENDPOINT_URL=

# Dependency checks (set false to run without infra in dev)
REQUIRE_REDIS=true
REQUIRE_POSTGRES=true

# Upload limits (bytes)
MAX_UPLOAD_BYTES=25000000
MAX_REMOTE_BYTES=25000000

# ── LLM Providers ──────────────────────────────────────────────────────────────
# Which provider to use: stub | lmstudio | ollama | openai | anthropic
# Default is "stub" (no LLM — uses retrieved context only)
LLM_PROVIDER=stub

# LMStudio — local-first, OpenAI-compatible API
# OPENAI_BASE_URL=http://127.0.0.1:1234
# OPENAI_MODEL=mistral-7b-instruct-v0.3

# Ollama — local models via Ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.1

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=   # leave blank for api.openai.com

# Anthropic / Claude
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Auth ───────────────────────────────────────────────────────────────────────
AUTH_REQUIRED=false

# ── Notifications (Telegram) ───────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
